@model IReadOnlyList<CustomerListItemViewModel>
@{
    ViewData["Title"] = "Customers";
}

<div class="page-actions">
    <div>
        <p class="text-muted mb-1">Simple and GDPR-conscious customer records for traceable transactions.</p>
        <h2 class="section-title mb-0">Customer Management</h2>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Customer</a>
</div>

<section class="surface-card table-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>City</th>
                    <th>Transactions</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.ContactData</td>
                    <td>@item.City</td>
                    <td>@item.TransactionsCount</td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
