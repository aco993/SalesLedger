@model IReadOnlyList<ProductListItemViewModel>
@{
    ViewData["Title"] = "Products";
}

<div class="page-actions">
    <div>
        <p class="text-muted mb-1">Reusable product master data supports cleaner reporting and future dimensions.</p>
        <h2 class="section-title mb-0">Product Management</h2>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Product</a>
</div>

<section class="surface-card table-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Default Price</th>
                    <th>Status</th>
                    <th>Transactions</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.Category</td>
                    <td>@(item.DefaultPrice?.ToString("C", CultureInfo.GetCultureInfo("de-DE")) ?? "-")</td>
                    <td><span class="badge @(item.IsActive ? "badge-soft" : "badge-danger-soft")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                    <td>@item.TransactionsCount</td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
