@model IReadOnlyList<ImportLogListItemViewModel>
@{
    ViewData["Title"] = "Imports";
}

<section class="row g-4">
    <div class="col-xl-8">
        <div class="surface-card table-card">
            <div class="page-actions">
                <div>
                    <p class="text-muted mb-1">Preparation area for future Excel and scanned-source ingestion.</p>
                    <h2 class="section-title mb-0">Import Logs</h2>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Import Date</th>
                            <th>Seller</th>
                            <th>Imported</th>
                            <th>Failed</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.FileName</div>
                                <small class="text-muted">@item.ErrorMessage</small>
                            </td>
                            <td>@item.ImportDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.SellerName</td>
                            <td>@item.ImportedRows</td>
                            <td>@item.FailedRows</td>
                            <td><span class="badge @(item.Status.ToString().Contains("Failed") ? "badge-danger-soft" : "badge-soft")">@item.Status</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="surface-card info-card h-100">
            <h3 class="section-title">Future Import Module</h3>
            <p class="text-muted">The current solution already contains the persistence and service boundary for future import workflows.</p>
            <ul class="mb-0">
                <li>Excel parser service can be added behind the existing import layer.</li>
                <li>OCR and handwritten recognition can create staged records before posting transactions.</li>
                <li>Import logs already capture file, seller, status and row-quality outcomes.</li>
            </ul>
        </div>
    </div>
</section>
