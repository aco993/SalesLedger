@model TransactionFormViewModel

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="TransactionDate" class="form-label"></label>
        <input asp-for="TransactionDate" class="form-control" />
        <span asp-validation-for="TransactionDate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="SellerId" class="form-label"></label>
        <select asp-for="SellerId" class="form-select" asp-items="@(new SelectList(Model.SellerOptions, "Value", "Text"))">
            <option value="">Select seller</option>
        </select>
        <span asp-validation-for="SellerId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CustomerId" class="form-label"></label>
        <select asp-for="CustomerId" class="form-select" asp-items="@(new SelectList(Model.CustomerOptions, "Value", "Text"))">
            <option value="">Optional customer</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="BuyerName" class="form-label"></label>
        <input asp-for="BuyerName" class="form-control" />
        <span asp-validation-for="BuyerName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ProductId" class="form-label"></label>
        <select asp-for="ProductId" class="form-select" asp-items="@(new SelectList(Model.ProductOptions, "Value", "Text"))">
            <option value="">Select product</option>
        </select>
        <span asp-validation-for="ProductId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Quantity" class="form-label"></label>
        <input asp-for="Quantity" class="form-control" data-transaction-quantity />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="UnitPrice" class="form-label"></label>
        <input asp-for="UnitPrice" class="form-control" data-transaction-unitprice />
        <span asp-validation-for="UnitPrice" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="TotalAmount" class="form-label"></label>
        <input asp-for="TotalAmount" class="form-control" data-transaction-total />
        <span asp-validation-for="TotalAmount" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="PaymentType" class="form-label"></label>
        <select asp-for="PaymentType" class="form-select" asp-items="Html.GetEnumSelectList<SalesLedger.Domain.Enums.PaymentType>()"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="SourceType" class="form-label"></label>
        <select asp-for="SourceType" class="form-select" asp-items="Html.GetEnumSelectList<SalesLedger.Domain.Enums.TransactionSourceType>()"></select>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
</div>
