@model TransactionIndexViewModel
@{
    ViewData["Title"] = "Transactions";
}

<div class="page-actions">
    <div>
        <p class="text-muted mb-1">Search, filter and review operational sales data.</p>
        <h2 class="section-title mb-0">Transaction Management</h2>
    </div>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle"></i> New Transaction</a>
</div>

<section class="surface-card form-card mb-4">
    <form method="get" class="row g-3">
        <div class="col-md-2">
            <label asp-for="Filter.FromDate" class="form-label">From</label>
            <input asp-for="Filter.FromDate" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.ToDate" class="form-label">To</label>
            <input asp-for="Filter.ToDate" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.SellerId" class="form-label">Seller</label>
            <select asp-for="Filter.SellerId" class="form-select" asp-items="@(new SelectList(Model.SellerOptions, "Value", "Text"))">
                <option value="">All sellers</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.ProductId" class="form-label">Product</label>
            <select asp-for="Filter.ProductId" class="form-select" asp-items="@(new SelectList(Model.ProductOptions, "Value", "Text"))">
                <option value="">All products</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.SourceType" class="form-label">Source</label>
            <select asp-for="Filter.SourceType" class="form-select" asp-items="@(new SelectList(Model.SourceTypeOptions, "Value", "Text"))">
                <option value="">All sources</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.SearchTerm" class="form-label">Search</label>
            <input asp-for="Filter.SearchTerm" class="form-control" placeholder="Buyer, seller, product" />
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Apply Filters</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>
</section>

<section class="surface-card table-card">
    @if (Model.Transactions.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <p class="mb-0">No transactions matched the current filter set.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Seller</th>
                        <th>Product</th>
                        <th>Customer / Buyer</th>
                        <th>Qty</th>
                        <th>Payment</th>
                        <th>Source</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Transactions)
                {
                    <tr>
                        <td>@item.TransactionDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.SellerName</td>
                        <td>@item.ProductName</td>
                        <td>@item.CustomerDisplayName</td>
                        <td>@item.Quantity</td>
                        <td><span class="badge badge-soft">@item.PaymentType</span></td>
                        <td><span class="badge badge-warning-soft">@item.SourceType</span></td>
                        <td class="text-end fw-semibold">@item.TotalAmount.ToString("C", CultureInfo.GetCultureInfo("de-DE"))</td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">View</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                <form method="post" asp-action="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Delete this transaction?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
